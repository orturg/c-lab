<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiUI.Pages.WarehousesPage"
             Title="Склади">

    <CollectionView x:Name="WarehousesCollection"
                    SelectionMode="Single"
                    SelectionChanged="OnWarehouseSelected"
                    Margin="16,8">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <VerticalStackLayout Padding="0,12" Spacing="2">
                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                    <Label Text="{Binding LocationDisplay}" FontSize="13" />
                    <BoxView HeightRequest="1" Color="LightGray" Margin="0,10,0,0" />
                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>