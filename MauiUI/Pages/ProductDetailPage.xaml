<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiUI.Pages.ProductDetailPage"
             Title="Деталі товару">

    <ScrollView>
        <VerticalStackLayout Padding="16,12" Spacing="10">

            <Label x:Name="ProductNameLabel" FontSize="18" FontAttributes="Bold" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Категорія:" FontAttributes="Bold" FontSize="14" />
                <Label Grid.Column="1" x:Name="CategoryLabel" FontSize="14" />
            </Grid>

            <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Кількість:" FontAttributes="Bold" FontSize="14" />
                <Label Grid.Column="1" x:Name="QuantityLabel" FontSize="14" />
            </Grid>

            <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Ціна за од.:" FontAttributes="Bold" FontSize="14" />
                <Label Grid.Column="1" x:Name="UnitPriceLabel" FontSize="14" />
            </Grid>

            <Grid ColumnDefinitions="130,*" ColumnSpacing="8">
                <Label Grid.Column="0" Text="Загальна:" FontAttributes="Bold" FontSize="14" />
                <Label Grid.Column="1" x:Name="TotalValueLabel" FontSize="14" />
            </Grid>

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label Text="Опис:" FontAttributes="Bold" FontSize="14" />
            <Label x:Name="DescriptionLabel" FontSize="14" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>